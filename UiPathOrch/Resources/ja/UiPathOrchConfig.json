{
  /* ================= グローバル設定 ここから ================== */

  // ルートノードに記載されたグローバル設定は、すべての PSDrive で共有されます。
  // これらの設定は、各 PSDrive の設定で同じキーを指定することで上書きできます。
  // 各 PSDrive に設定された値を確認するには、次を実行してください:
  // Get-OrchPSDrive | select *

  // テナントの管理ページで非機密の外部アプリを作成したら、
  // リダイレクト URL には下記と同じ値を設定してください。
  "RedirectUrl": "http://localhost:8085/Temporary_Listen_Addresses",

  // "Edition" は、対象環境向けに UiPathOrch がどのような URL を組み立てるかを
  // 指示します。指定可能な値は "Cloud" / "AutomationSuite" / "OnPremises" です。
  // 省略時には Root の URL から自動推定されます:
  //   - ホストに "uipath.com" を含む       => Cloud
  //   - パスが 2 セグメント (/org/tenant)  => AutomationSuite
  //   - それ以外                           => OnPremises
  // 自動推定が外れる場合（例: 多段リバースプロキシ配下のオンプレ
  // Orchestrator で 2 セグメントになるケース）は、明示的に指定してください。
  // "Edition": "AutomationSuite",

  // ここで定義された "Scope" は、各 PSDrive の設定で指定された "Scope" により
  // 上書きされます。この "Scope" を使用するには、該当する PSDrive の設定から
  // "Scope" キーを削除してください。各 cmdlet の実行に必要なスコープを確認
  // するには、次を実行してください: Get-Help <cmdlet name>
  "Scope": "OR.Folders.Read OR.Settings.Read OR.Users.Read",

  // 名詞が OrchPm で始まる cmdlet を使用するには、Platform Management API
  // Access のスコープを追加してください。なお、cmdlet で Active Directory を
  // 操作するには、テナントではなく組織にログインする必要があります。
  // UiPathOrch で組織にログインするには、まずブラウザーで組織にログインした
  // 後に UiPathOrch を使用してください。ブラウザーで組織にログインするには、
  // まずテナントからログオフし、組織の URL（末尾のテナント名を除いたもの）を
  // ブラウザーで開いてログインしてください。

  // Platform Management のほか、Document Understanding や TestManager の
  // スコープも指定できます。

  // HTTP ログを出力できます。
  // ログ出力フォルダを開くには、Open-OrchLogLocation cmdlet を実行します。
  "Logging": {
    // 指定できるレベルは、Error, Info, Trace, Verbose のいずれかです。
    "Level": "Info",
    "Enabled": false
  },

  // 下記を true に設定すると、SSL エラーを無視してテナントに接続できます。
  "IgnoreSslErrors": false,

  "Proxy": {
    // これを true にすると、すべての PSDrive でプロキシ設定が有効になります。
    "Enabled": false,

    // これを true にすると、インターネットオプションで構成されたプロキシ設定を
    // 使用します。その場合、以降の設定（"Url"など）はすべて無視されます。
    "UseDefaultWebProxy": true,

    "Url": "http://proxy.example.com:8080",
    "BypassProxyOnLocal": true,
    "UseDefaultCredentials": false,
    "Credentials": {
      "Username": "PROXY_USERNAME",
      "Password": "PROXY_PASSWORD"
    }
  },

  /* ================= グローバル設定 ここまで ================== */

  "PSDrives": [

    /* ============== 個人用アクセストークンの設定例 ============== */
    // 個人用アクセストークンは、Orchestrator の設定ページで
    // 作成できます。この構成を使用する場合には
    // OAuth 外部アプリケーションを作成する必要はありません。
    //
    // 重要: トークンのスコープは、サーバー側での作成時に確定します。
    // 作成時には最低限、次のスコープを選択してください:
    //   OR.Folders.Read   (フォルダーツリーの取得)
    //   OR.Settings.Read  (API バージョンの検出)
    //   OR.Users.Read     (個人用ワークスペースへのアクセス)
    // 加えて、操作したい対象のスコープ (OR.Assets、OR.Queues など) も
    // 選択してください。
    // この設定例に "Scope" が無いのは意図的です。"Scope" を書いても
    // トークンの権限は変わりません。Du*/Tm* ドライブを有効にする場合に
    // 限り宣言してください (例: "Scope": "Du.Digitization TM.TestCases")。
    {
      "Name": "Orch1",
      "Description": "個人用アクセストークンを使用した設定。",
      "Root": "https://cloud.uipath.com/YOUR_ORGANIZATION/YOUR_TENANT",
      "AccessToken": "YOUR_PERSONAL_ACCESS_TOKEN",
      "Enabled": true
    },

    /* =================== 非機密アプリの設定例 =================== */
    // Orchestrator の管理ページで外部アプリを作成し、Orchestrator API
    // Access のユーザースコープを追加したら、下記の "Scope" に転記して
    // ください。
    // また、その外部アプリのリダイレクト URL には、このファイルのグローバル
    // 設定に記載されたリダイレクト URL をコピーして転記してください。
    {
      // "Name" には任意のテキストを設定できます。
      // テナント名と同じにすることをお勧めします。
      "Name": "Orch2",
      "Description": "非機密アプリの設定。",
      "Root": "https://cloud.uipath.com/YOUR_ORGANIZATION/YOUR_TENANT",
      "AppId": "YOUR_APP_ID",
      "Scope": "OR.Folders.Read OR.Settings.Read OR.Users.Read",
      "Enabled": false
    },

    /* ==================== 機密アプリの設定例 ==================== */
    // 機密アプリは、非機密アプリよりも一般的に安全性が低いと見なされます。
    // それは、この設定ファイル内に AppSecret を保存する必要があるためです。
    // AppSecret は機密性の高い認証情報であり、漏洩のリスクがあります。
    // そのため、機密アプリは無人スクリプト実行専用としてのみ使用してください。
    //
    // Orchestrator の管理ページで外部アプリを作成し、Orchestrator API
    // Access の必要なアプリスコープを下記のスコープ以上に設定してください。
    // リダイレクト URL の設定は不要です。
    {
      "Name": "Orch3",
      "Description": "機密アプリの設定。",
      "Root": "https://cloud.uipath.com/YOUR_ORGANIZATION/YOUR_TENANT",
      "AppId": "YOUR_APP_ID",
      "AppSecret": "YOUR_APP_SECRET",
      "Scope": "OR.Folders.Read OR.Settings.Read",
      "Enabled": false
    },

    /* ============ ユーザー名とパスワード認証の設定例 ============ */
    // この認証方法は非推奨ですが、古いバージョンのオンプレミス Orchestrator
    // に接続する場合に必要となります。
    // 外部アプリがサポートされたバージョン 21.4 以降では、外部アプリを
    // 使用してください。URL の末尾に YOUR_TENANT を必ず記載してください。
    {
      "Name": "Orch4",
      "Description": "ユーザー名とパスワード認証。",
      "Root": "https://YOUR_ORCHESTRATOR_URL/YOUR_TENANT",
      "Username": "USERNAME_OR_EMAILADDR",
      "Password": "PASSWORD",
      "Scope": "OR.Folders.Read OR.Settings.Read",
      "Enabled": false
    },

    /* ====== Azure App Service 上の Orchestrator 認証の設定例 ====== */
    // シングルテナントの Orchestrator を Azure App Service にデプロイする
    // 場合は、"IdentityUrl" キーに ID サーバーの URL を記載してください。
    // 認証に関するその他の設定については、非機密アプリまたは機密アプリの
    // 設定を参照してください。
    {
      "Name": "Orch5",
      "Description": "Azure App Service にデプロイされた Orchestrator の設定。",
      "Root": "https://XXX.azurewebsites.net",
      "IdentityUrl": "https://YYY.azurewebsites.net/identity",
      "AppId": "YOUR_APP_ID",
      "Scope": "OR.Folders.Read OR.Settings.Read OR.Users.Read",
      "Enabled": false
    },

    /* ============= Automation Suite 認証の設定例 ============= */
    // セルフホスト型の Automation Suite では、URL に組織とテナントが
    // 含まれます: https://YOUR_HOST/YOUR_ORGANIZATION/YOUR_TENANT
    // この 2 セグメントのパスから Edition は自動推定されますが、
    // 明示しておくと曖昧さがなくなります。AS 環境では UiPathOrch が
    // Orchestrator API 呼び出しを自動的に /orchestrator_/ 経由でルーティング
    // します。
    {
      "Name": "Orch7",
      "Description": "Automation Suite (セルフホスト, マルチテナント)。",
      "Root": "https://YOUR_AS_HOST/YOUR_ORGANIZATION/YOUR_TENANT",
      "Edition": "AutomationSuite",
      "AppId": "YOUR_APP_ID",
      "Scope": "OR.Folders.Read OR.Settings.Read OR.Users.Read",
      "Enabled": false
    },

    /* ===================== プロキシの設定例 ===================== */
    // この PSDrive 内の "Proxy" セクションは、ルートレベルで定義された
    // グローバルプロキシ設定を上書きし、この PSDrive に対して異なる
    // プロキシ設定を使用できるようにします。
    {
      "Name": "Orch6",
      "Description": "この設定にはプロキシ設定が含まれます。",
      "Root": "https://cloud.uipath.com/YOUR_ORGANIZATION/YOUR_TENANT",
      "AppId": "YOUR_APP_ID",
      "Scope": "OR.Folders.Read OR.Settings.Read OR.Users.Read",
      "Enabled": false,

      "Proxy": {
        "UseDefaultWebProxy": false,
        "Url": "http://proxy.example.com:8081",
        "BypassProxyOnLocal": true,
        "UseDefaultCredentials": false,
        "Credentials": {
          "Username": "PROXY_USERNAME",
          "Password": "PROXY_PASSWORD"
        },
        "Enabled": true
      }
    },
  ]
}
