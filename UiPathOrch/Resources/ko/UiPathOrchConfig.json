{
  /* ================== 글로벌 설정 시작 =================== */

  // 루트 노드의 글로벌 설정은 모든 PSDrive에서 공유됩니다.
  // 이러한 설정은 개별 PSDrive 구성에서 동일한 키를 지정하여
  // 재정의할 수 있습니다.
  // 각 PSDrive에 구성된 값을 확인하려면 다음을 실행하세요:
  // Get-OrchPSDrive | select *

  // 테넌트 관리 페이지에서 기밀이 아닌 외부 애플리케이션을 생성한 후,
  // 해당 리디렉션 URL을 아래 지정된 값으로 설정하세요.
  "RedirectUrl": "http://localhost:8085/Temporary_Listen_Addresses",

  // "Edition"은 대상 배포 환경에 맞춰 UiPathOrch가 URL을 어떻게
  // 조립할지를 지정합니다. 유효한 값: "Cloud", "AutomationSuite",
  // "OnPremises". 생략 시 Root URL에서 자동으로 추정됩니다:
  //   - 호스트가 "uipath.com"을 포함      => Cloud
  //   - 경로가 두 세그먼트 (/org/tenant)  => AutomationSuite
  //   - 그 외                             => OnPremises
  // 자동 추정이 어긋나는 경우(예: 다단 리버스 프록시 뒤에 두 세그먼트
  // 경로를 갖는 온프레미스 Orchestrator)에는 명시적으로 지정하세요.
  // "Edition": "AutomationSuite",

  // 여기에서 정의된 "Scope"는 각 PSDrive 구성에 지정된 "Scope"에
  // 의해 재정의됩니다.
  // 이 Scope를 사용하려면 해당 PSDrive 구성에서 Scope 키를 제거하세요.
  // 각 Cmdlet을 실행하는 데 필요한 Scope를 확인하려면 다음을 실행하세요:
  // Get-Help <cmdlet name>
  "Scope": "OR.Folders.Read OR.Settings.Read OR.Users.Read",

  // OrchPm으로 시작하는 명사를 가진 Cmdlet을 사용하려면 플랫폼 관리
  // API 액세스 Scope를 추가하세요.
  // Active Directory를 관리하려면 테넌트가 아닌 조직에 로그인해야 합니다.

  // UiPathOrch를 사용하여 조직에 로그인하려면 먼저 브라우저에서
  // 조직에 로그인한 후 UiPathOrch를 사용하세요.
  // 브라우저에서 조직에 로그인하려면 먼저 테넌트에서 로그아웃한 후,
  // 조직의 URL(끝에 테넌트 이름이 없는)을 열어 로그인하세요.

  // 플랫폼 관리 외에도 Document Understanding 및 TestManager에 대한
  // Scope를 지정할 수 있습니다.

  // HTTP 로그를 출력할 수 있습니다.  
  // 로그 출력 폴더를 열려면 Open-OrchLogLocation cmdlet을 실행하세요.
  "Logging": {
    // 설정할 수 있는 로그 레벨은 Error, Info, Trace, Verbose 중 하나입니다.
    "Level": "Info",
    "Enabled": false
  },

  // 이 값을 true로 설정하면 SSL 오류를 무시하고 테넌트에 연결할 수 있습니다.
  "IgnoreSslErrors": false,

  "Proxy": {
    // 이 값을 true로 설정하면 모든 PSDrive에서 프록시 설정이 활성화됩니다.
    "Enabled": false,

    // true로 설정하면 인터넷 옵션에 구성된 프록시 설정을 사용합니다.
    // 이 경우, 이후의 모든 설정("Url" 등)은 무시됩니다.
    "UseDefaultWebProxy": true,

    "Url": "http://proxy.example.com:8080",
    "BypassProxyOnLocal": true,
    "UseDefaultCredentials": false,
    "Credentials": {
      "Username": "PROXY_USERNAME",
      "Password": "PROXY_PASSWORD"
    }
  },

  /* =================== 글로벌 설정 종료 ==================== */

  "PSDrives": [

    /* ================ 개인 액세스 토큰 예시 ================ */
    // 개인 액세스 토큰은 Orchestrator의 환경 설정 페이지에서
    // 생성할 수 있습니다. 이 구성을 사용하는 경우에는
    // OAuth 외부 애플리케이션을 생성할 필요가 없습니다.
    //
    // 중요: 토큰의 스코프는 서버에서 토큰을 생성할 때 확정됩니다.
    // 토큰 생성 시 최소한 다음 스코프를 선택하세요:
    //   OR.Folders.Read   (폴더 트리 조회)
    //   OR.Settings.Read  (API 버전 감지)
    //   OR.Users.Read     (개인 작업 영역 액세스)
    // 또한 관리하려는 대상의 스코프(OR.Assets, OR.Queues 등)도
    // 선택하세요. 이 예시에 "Scope"가 없는 것은 의도적입니다.
    // "Scope"를 지정해도 토큰의 권한은 변경되지 않습니다. Du*/Tm*
    // 드라이브를 활성화할 때만 선언하세요
    // (예: "Scope": "Du.Digitization TM.TestCases").
    {
      "Name": "Orch1",
      "Description": "이 구성에는 개인 액세스 토큰이 포함되어 있습니다.",
      "Root": "https://cloud.uipath.com/YOUR_ORGANIZATION/YOUR_TENANT",
      "AccessToken": "YOUR_PERSONAL_ACCESS_TOKEN",
      "Enabled": true
    },

    /* =========== 기밀이 아닌 애플리케이션 설정 샘플 =========== */
    // Orchestrator 관리 페이지에서 외부 애플리케이션을 생성한 후
    // Orchestrator API 액세스를 위한 사용자 스코프를 추가하고, 아래 "Scope"
    // 필드에 입력하세요. 이 파일의 글로벌 설정 섹션에서 리디렉션 URL을
    // 복사하여 테넌트의 외부 애플리케이션 설정에 붙여넣으세요.
    {
      // Name에 원하는 텍스트를 설정할 수 있습니다.
      // 테넌트 이름과 동일하게 설정하는 것을 권장합니다.
      "Name": "Orch2",
      "Description": "기밀이 아닌 애플리케이션 설정.",
      "Root": "https://cloud.uipath.com/YOUR_ORGANIZATION/YOUR_TENANT",
      "AppId": "YOUR_APP_ID",
      "Scope": "OR.Folders.Read OR.Settings.Read OR.Users.Read",
      "Enabled": false
    },

    /* ============= 기밀 애플리케이션 설정 샘플 ============= */
    // 기밀 애플리케이션은 일반적으로 비기밀 애플리케이션보다 보안성이 낮다고
    // 간주됩니다. 이는 이 구성 파일에 AppSecret을 저장해야 하기 때문입니다.
    // AppSecret은 민감한 자격 증명이므로 유출 위험이 있습니다.
    // 따라서 무인 스크립트 실행에만 사용해야 합니다.
    //
    // Orchestrator 관리 페이지에서 외부 애플리케이션을 생성하고
    // 아래 나열된 스코프와 일치하거나 초과하는 Orchestrator API
    // 액세스를 위한 필수 App Scope를 추가하세요.
    // 리디렉션 URL은 필요하지 않습니다.
    // 이 구성에서 Root, 발급된 AppId, AppSecret을 지정하세요.
    {
      "Name": "Orch3",
      "Description": "기밀 애플리케이션 설정.",
      "Root": "https://cloud.uipath.com/YOUR_ORGANIZATION/YOUR_TENANT",
      "AppId": "YOUR_APP_ID",
      "AppSecret": "YOUR_APP_SECRET",
      "Scope": "OR.Folders.Read OR.Settings.Read",
      "Enabled": false
    },

    /* ======= 사용자 이름 및 비밀번호 인증 샘플 ======== */
    // 이 인증 방법은 더 이상 권장되지 않지만, 이전 버전의 온프레미스
    // Orchestrator에 연결할 때 필요합니다.
    // OAuth 외부 애플리케이션 지원은 버전 21.4에서 도입되었습니다.
    // URL 끝에 YOUR_TENANT을 반드시 지정하세요.
    {
      "Name": "Orch4",
      "Description": "사용자 이름 및 비밀번호 인증.",
      "Root": "https://YOUR_ORCHESTRATOR_URL/YOUR_TENANT",
      "Username": "USERNAME_OR_EMAILADDR",
      "Password": "PASSWORD",
      "Scope": "OR.Folders.Read OR.Settings.Read",
      "Enabled": false
    },

    /* ===== Azure App Service의 Orchestrator 인증 샘플 ===== */
    // Azure App Service에 배포된 단일 테넌트 Orchestrator의 경우,
    // "IdentityUrl" 키를 사용하여 ID 서버 URL을 지정하세요.
    // 인증 관련 설정은 비기밀 애플리케이션 또는 기밀 애플리케이션 설정을
    // 참조하세요.
    {
      "Name": "Orch5",
      "Description": "Azure App Service에 배포된 Orchestrator용.",
      "Root": "https://XXX.azurewebsites.net",
      "IdentityUrl": "https://YYY.azurewebsites.net/identity",
      "AppId": "YOUR_APP_ID",
      "Scope": "OR.Folders.Read OR.Settings.Read OR.Users.Read",
      "Enabled": false
    },

    /* ========== Automation Suite 인증 샘플 ========== */
    // 자체 호스팅 Automation Suite의 URL에는 조직과 테넌트가 포함됩니다:
    // https://YOUR_HOST/YOUR_ORGANIZATION/YOUR_TENANT
    // 두 세그먼트 경로에서 Edition은 자동 감지되지만, 명시적으로 설정하면
    // 모호함을 피할 수 있습니다. AS 환경에서는 UiPathOrch가
    // Orchestrator API 호출을 자동으로 /orchestrator_/ 경로를 거쳐
    // 라우팅합니다.
    {
      "Name": "Orch7",
      "Description": "Automation Suite (자체 호스팅, 멀티 테넌트).",
      "Root": "https://YOUR_AS_HOST/YOUR_ORGANIZATION/YOUR_TENANT",
      "Edition": "AutomationSuite",
      "AppId": "YOUR_APP_ID",
      "Scope": "OR.Folders.Read OR.Settings.Read OR.Users.Read",
      "Enabled": false
    },

    /* ================== 프록시 설정 샘플 =================== */
    // 이 PSDrive의 "Proxy" 섹션은 루트 수준에서 정의된 글로벌 프록시
    // 설정을 재정의하여, 이 PSDrive가 글로벌 설정과 다른 프록시 구성을
    // 사용할 수 있도록 합니다.
    {
      "Name": "Orch6",
      "Description": "이 구성에는 프록시 설정이 포함됩니다.",
      "Root": "https://cloud.uipath.com/YOUR_ORGANIZATION/YOUR_TENANT",
      "AppId": "YOUR_APP_ID",
      "Scope": "OR.Folders.Read OR.Settings.Read OR.Users.Read",
      "Enabled": false,
      "Proxy": {
        "UseDefaultWebProxy": false,
        "Url": "http://proxy.example.com:8081",
        "BypassProxyOnLocal": true,
        "UseDefaultCredentials": false,
        "Credentials": {
          "Username": "PROXY_USERNAME",
          "Password": "PROXY_PASSWORD"
        },
        "Enabled": true
      }
    },
  ]
}
