{
  /* ================== Global Settings Start =================== */

  // The global settings in the root node are shared across all PSDrives.
  // These settings can be overridden by specifying the same keys in
  // individual PSDrive configurations.
  // To check the values configured for each PSDrive,
  // run: Get-OrchPSDrive | select *

  // After creating a non-confidential external application in the tenant's
  // administration page, set its Redirect URL to the value specified below.
  "RedirectUrl": "http://localhost:8085/Temporary_Listen_Addresses",

  // The "Scope" defined here will be overridden by the "Scope" specified in
  // each PSDrive's configuration.
  // To use this Scope, remove the Scope key from the corresponding PSDrive
  // configuration.
  // To check the scopes required for executing each cmdlet,
  // run: Get-Help <cmdlet name>
  "Scope": "OR.Folders.Read OR.Settings.Read OR.Users.Read",

  // To use cmdlets whose noun starts with OrchPm, add the Platform
  // Management API Access scope.
  // Note that to operate Active Directory, you need to log in to the
  // organization (not the tenant).

  // To log in to the organization using UiPathOrch, first log in to the
  // organization via a browser, then use UiPathOrch.
  // To log in to the organization via a browser, first log out from the
  // tenant, then open the organization's URL
  // (without the tenant name at the end) in a browser and log in.

  // In addition to Platform Management, you can also specify scopes for
  // Document Understanding and TestManager.

  // HTTP logs can be output.
  // To open the log output folder, run the Open-OrchLogLocation cmdlet.
  "Logging": {
    // The available levels are Error, Info, Trace, and Verbose.
    "Level": "Info",
    "Enabled": false
  },

  // Setting this to true allows connecting to the tenant while ignoring
  // SSL errors.
  "IgnoreSslErrors": false,

  "Proxy": {
    "Url": "http://proxy.example.com:8080",
    "BypassProxyOnLocal": true,
    "UseDefaultCredentials": false,
    "Credentials": {
      "Username": "PROXY_USERNAME",
      "Password": "PROXY_PASSWORD"
    },
    // Setting this to true enables proxy settings for all PSDrives.
    "Enabled": false
  },

  /* =================== Global Settings End ==================== */

  "PSDrives": [

    /* =========== Non-Confidential App Settings Sample =========== */
    // After creating an external application in the Orchestrator
    // administration page and adding user scopes for Orchestrator
    // API Access, enter them in the "Scope" field below.
    // Copy the Redirect URL from the global settings section of this file
    // and paste it into the external application settings of your tenant.
    {
      // You can set any text for the Name.
      // It is recommended to match it with the tenant name.
      "Name": "Orch1",
      "Description": "Non-Confidential App settings.",
      "Root": "https://cloud.uipath.com/YOUR_ORGANIZATION/YOUR_TENANT",
      "AppId": "YOUR_APP_ID",
      "Scope": "OR.Folders.Read OR.Settings.Read OR.Users.Read",
      "Enabled": true
    },

    /* ============= Confidential App Settings Sample ============= */
    // A Confidential App is generally considered less secure than
    // a Non-Confidential App because it requires storing an AppSecret in
    // this configuration file. Since the AppSecret is a sensitive credential,
    // there is a risk of exposure. Therefore, it should only be used for
    // unattended script executions.
    //
    // In the Orchestrator admin page, create an external application and
    // add the required App Scopes for Orchestrator API Access to match or
    // exceed the scopes listed below. No Redirect URL is needed.
    // In this configuration, specify Root, issued AppId, and AppSecret.
    {
      "Name": "Orch2",
      "Description": "Confidential App settings.",
      "Root": "https://cloud.uipath.com/YOUR_ORGANIZATION/YOUR_TENANT",
      "AppId": "YOUR_APP_ID",
      "AppSecret": "YOUR_APP_SECRET",
      "Scope": "OR.Folders.Read OR.Settings.Read",
      "Enabled": false
    },

    /* ======= Username and Password Authentication Sample ======== */
    // This authentication method is deprecated but is necessary when
    // connecting to earlier versions of on-premises Orchestrator.
    // Support for OAuth external applications was introduced in version 21.4.
    // Ensure that you specify YOUR_TENANT at the end of the URL.
    {
      "Name": "Orch3",
      "Description": "Username and password authentication.",
      "Root": "https://YOUR_ORCHESTRATOR_URL/YOUR_TENANT",
      "Username": "USERNAME_OR_EMAILADDR",
      "Password": "PASSWORD",
      "Scope": "OR.Folders.Read OR.Settings.Read",
      "Enabled": false
    },

    /* ========== Automation Suite Authentication Sample ========== */
    // In this configuration, specify the Identity Server URL using
    // the "IdentityUrl" key. For authentication-related settings, refer to
    // the Non-Confidential App or Confidential App configurations.
    {
      "Name": "Orch4",
      "Description": "For AS or Orchestrator deployed on Azure App Service.",
      "Root": "https://XXX.azurewebsites.net",
      "IdentityUrl": "https://YYY.azurewebsites.net/identity",
      "AppId": "YOUR_APP_ID",
      "Scope": "OR.Folders.Read OR.Settings.Read OR.Users.Read",
      "Enabled": false
    },

    /* ================== Proxy Settings Sample =================== */
    // The "Proxy" section within this PSDrive will override the global
    // proxy settings defined at the root level, allowing this PSDrive to use
    // a different proxy configuration from the global settings.
    {
      "Name": "Orch5",
      "Description": "This configuration includes proxy settings.",
      "Root": "https://cloud.uipath.com/YOUR_ORGANIZATION/YOUR_TENANT",
      "AppId": "YOUR_APP_ID",
      "Scope": "OR.Folders.Read OR.Settings.Read OR.Users.Read",
      "Enabled": false,

      "Proxy": {
        "Url": "http://proxy.example.com:8081",
        "BypassProxyOnLocal": true,
        "UseDefaultCredentials": false,
        "Credentials": {
          "Username": "PROXY_USERNAME",
          "Password": "PROXY_PASSWORD"
        },
        "Enabled": true
      }
    }
  ]
}
