    <View>
      <Name>BulkOperationResponse</Name>
      <ViewSelectedBy>
        <TypeName>UiPath.PowerShell.Entities.BulkOperationResponse</TypeName>
      </ViewSelectedBy>
      <GroupBy>
        <Label>Queue</Label>
        <PropertyName>PathQueue</PropertyName>
      </GroupBy>
      <TableControl>
        <TableHeaders>
          <TableColumnHeader>
            <Label>Success</Label>
          </TableColumnHeader>
          <TableColumnHeader>
            <Label>Message</Label>
          </TableColumnHeader>
          <TableColumnHeader>
            <Label>FailedItems</Label>
          </TableColumnHeader>
        </TableHeaders>
        <TableRowEntries>
          <TableRowEntry>
            <TableColumnItems>
              <TableColumnItem>
                <PropertyName>Success</PropertyName>
              </TableColumnItem>
              <TableColumnItem>
                <PropertyName>Message</PropertyName>
              </TableColumnItem>
              <TableColumnItem>
                <ScriptBlock>
                  -join (($_.FailedItems | ForEach-Object { $_.ToString() }) -join ", ")
                </ScriptBlock>
              </TableColumnItem>
            </TableColumnItems>
          </TableRowEntry>
        </TableRowEntries>
      </TableControl>
    </View>

