    <View>
      <Name>Release</Name>
      <ViewSelectedBy>
        <TypeName>UiPath.PowerShell.Entities.Release</TypeName>
      </ViewSelectedBy>
      <GroupBy>
        <Label>Directory</Label>
        <PropertyName>Path</PropertyName>
      </GroupBy>
      <TableControl>
        <TableHeaders>
          <TableColumnHeader>
            <Label>Id</Label>
          </TableColumnHeader>
          <TableColumnHeader>
            <Label>Name</Label>
          </TableColumnHeader>
          <TableColumnHeader>
            <Label>ProcessVersion</Label>
          </TableColumnHeader>
          <TableColumnHeader>
            <Label>IsLatestVersion</Label>
          </TableColumnHeader>
          <TableColumnHeader>
            <Label>Priority</Label>
          </TableColumnHeader>
          <TableColumnHeader>
            <Label>Description</Label>
          </TableColumnHeader>
          <TableColumnHeader>
            <Label>ProcessType</Label>
          </TableColumnHeader>
        </TableHeaders>
        <TableRowEntries>
          <TableRowEntry>
            <TableColumnItems>
              <TableColumnItem>
                <PropertyName>Id</PropertyName>
                <Alignment>right</Alignment>
              </TableColumnItem>
              <TableColumnItem>
                <PropertyName>Name</PropertyName>
              </TableColumnItem>
              <TableColumnItem>
                <PropertyName>ProcessVersion</PropertyName>
                <Alignment>right</Alignment>
              </TableColumnItem>
              <TableColumnItem>
                <PropertyName>IsLatestVersion</PropertyName>
              </TableColumnItem>
              <TableColumnItem>
                <ScriptBlock>
                      if ($_.SpecificPriorityValue -ge 91)                                      { "Critical"   }
                  elseif ($_.SpecificPriorityValue -ge 81 -and $_.SpecificPriorityValue -le 90) { "Highest"    }
                  elseif ($_.SpecificPriorityValue -ge 71 -and $_.SpecificPriorityValue -le 80) { "VeryHigh"   }
                  elseif ($_.SpecificPriorityValue -ge 61 -and $_.SpecificPriorityValue -le 70) { "High"       }
                  elseif ($_.SpecificPriorityValue -ge 51 -and $_.SpecificPriorityValue -le 60) { "MediumHigh" }
                  elseif ($_.SpecificPriorityValue -ge 41 -and $_.SpecificPriorityValue -le 50) { "Medium"     }
                  elseif ($_.SpecificPriorityValue -ge 31 -and $_.SpecificPriorityValue -le 40) { "MediumLow"  }
                  elseif ($_.SpecificPriorityValue -ge 21 -and $_.SpecificPriorityValue -le 30) { "Low"        }
                  elseif ($_.SpecificPriorityValue -ge 11 -and $_.SpecificPriorityValue -le 20) { "VeryLow"    }
                  elseif                                      ($_.SpecificPriorityValue -le 10) { "Lowest"     }
                </ScriptBlock>
                <Alignment>left</Alignment>
              </TableColumnItem>
              <TableColumnItem>
                <PropertyName>Description</PropertyName>
              </TableColumnItem>
              <TableColumnItem>
                <PropertyName>ProcessType</PropertyName>
              </TableColumnItem>
            </TableColumnItems>
          </TableRowEntry>
        </TableRowEntries>
      </TableControl>
    </View>

