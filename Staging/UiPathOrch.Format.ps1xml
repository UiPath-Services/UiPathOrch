<?xml version="1.0" encoding="UTF-8"?>
<Configuration>

  <ViewDefinitions>

    <!--
      Default view for Invoke-OrchApi output: render every property of the record
      as a Name : Value list, grouped by Path (drive context where the call was
      issued). Each element is tagged with PSTypeName "UiPathOrch.ApiResponseItem"
      by InvokeOrchApiCommand. Endpoints expose arbitrary shapes, so a ScriptBlock
      enumerates the property bag at format time — Path is omitted from the body
      because GroupBy already surfaces it.
    -->
    <View>
      <Name>UiPathOrch.ApiResponseItem</Name>
      <ViewSelectedBy>
        <TypeName>UiPathOrch.ApiResponseItem</TypeName>
      </ViewSelectedBy>
      <GroupBy>
        <PropertyName>Path</PropertyName>
        <Label>Path</Label>
      </GroupBy>
      <CustomControl>
        <CustomEntries>
          <CustomEntry>
            <CustomItem>
              <ExpressionBinding>
                <ScriptBlock>
                  $obj = $_
                  $props = $obj.PSObject.Properties | Where-Object { $_.Name -ne 'Path' }
                  if (-not $props) { return '' }
                  $w = ($props.Name | Measure-Object Length -Maximum).Maximum
                  ($props | ForEach-Object { '{0} : {1}' -f $_.Name.PadRight($w), $_.Value }) -join [Environment]::NewLine
                </ScriptBlock>
              </ExpressionBinding>
              <NewLine/>
            </CustomItem>
          </CustomEntry>
        </CustomEntries>
      </CustomControl>
    </View>

    <!--
      Compare-Orch* family output. One row per entity: SideIndicator (<=, =>, <>, ==),
      Name, the reference-side Path and the difference-side DifferencePath (each single-sided
      — a "<=" row has no DifferencePath, a "=>" row has no Path), and a compact rendering of
      the per-property Differences (only populated on "<>" rows). ReferenceObject/
      DifferenceObject are intentionally omitted here — they're for downstream piping.
    -->
    <View>
      <Name>UiPath.PowerShell.Entities.OrchComparison</Name>
      <ViewSelectedBy>
        <TypeName>UiPath.PowerShell.Entities.OrchComparison</TypeName>
      </ViewSelectedBy>
      <TableControl>
        <TableHeaders>
          <TableColumnHeader>
            <Label>Side</Label>
            <Width>4</Width>
          </TableColumnHeader>
          <TableColumnHeader>
            <Label>Name</Label>
          </TableColumnHeader>
          <TableColumnHeader>
            <Label>Path</Label>
          </TableColumnHeader>
          <TableColumnHeader>
            <Label>DifferencePath</Label>
          </TableColumnHeader>
          <TableColumnHeader>
            <Label>Differences</Label>
          </TableColumnHeader>
        </TableHeaders>
        <TableRowEntries>
          <TableRowEntry>
            <TableColumnItems>
              <TableColumnItem>
                <PropertyName>SideIndicator</PropertyName>
              </TableColumnItem>
              <TableColumnItem>
                <PropertyName>Name</PropertyName>
              </TableColumnItem>
              <TableColumnItem>
                <PropertyName>Path</PropertyName>
              </TableColumnItem>
              <TableColumnItem>
                <PropertyName>DifferencePath</PropertyName>
              </TableColumnItem>
              <TableColumnItem>
                <ScriptBlock>
                  if ($_.Differences) { ($_.Differences | ForEach-Object { $_.ToString() }) -join '; ' } else { '' }
                </ScriptBlock>
              </TableColumnItem>
            </TableColumnItems>
          </TableRowEntry>
        </TableRowEntries>
      </TableControl>
    </View>

    <!--
      Get-/Set-/Copy-PmUserPreference emit one record per preference key for the
      connected user; group the rows under a "User: <Path><UserName>" header and show
      just Key and Value, since Path/User are surfaced by GroupBy.
    -->
    <View>
      <Name>PmUserPreference</Name>
      <ViewSelectedBy>
        <TypeName>UiPath.PowerShell.Entities.PmUserPreference</TypeName>
      </ViewSelectedBy>
      <GroupBy>
        <Label>User</Label>
        <PropertyName>PathUserName</PropertyName>
      </GroupBy>
      <TableControl>
        <TableHeaders>
          <TableColumnHeader>
            <Label>Key</Label>
          </TableColumnHeader>
          <TableColumnHeader>
            <Label>Value</Label>
          </TableColumnHeader>
        </TableHeaders>
        <TableRowEntries>
          <TableRowEntry>
            <TableColumnItems>
              <TableColumnItem>
                <PropertyName>Key</PropertyName>
              </TableColumnItem>
              <TableColumnItem>
                <ScriptBlock>
                  # UserLanguage.Date is a Unix-epoch-ms timestamp; render it as a
                  # local date/time for readability. Display only — the stored Value
                  # stays the raw string so CSV / Set-PmUserPreference round-trips.
                  if ($_.Key -eq 'UserLanguage.Date' -and "$($_.Value)" -match '^\d+$') {
                    [DateTimeOffset]::FromUnixTimeMilliseconds([int64]$_.Value).LocalDateTime
                  } else { $_.Value }
                </ScriptBlock>
              </TableColumnItem>
            </TableColumnItems>
          </TableRowEntry>
        </TableRowEntries>
      </TableControl>
    </View>

    <!--
      Get-/Set-PmNotificationSubscription emit one row per (topic, mode); group under a
      "Publisher: <Path><Publisher>" header and show the topic, mode and state.
    -->
    <View>
