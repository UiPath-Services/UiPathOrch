    <View>
      <Name>TmRequirement</Name>
      <ViewSelectedBy>
        <TypeName>UiPath.PowerShell.Entities.TmRequirement</TypeName>
      </ViewSelectedBy>
      <GroupBy>
        <Label>Project</Label>
        <PropertyName>Path</PropertyName>
      </GroupBy>
      <TableControl>
        <TableHeaders>
          <TableColumnHeader>
            <Label>objKey</Label>
          </TableColumnHeader>
          <TableColumnHeader>
            <Label>name</Label>
          </TableColumnHeader>
          <TableColumnHeader>
            <Label>description</Label>
          </TableColumnHeader>
          <TableColumnHeader>
            <Label>updated</Label>
          </TableColumnHeader>
        </TableHeaders>
        <TableRowEntries>
          <TableRowEntry>
            <TableColumnItems>
              <TableColumnItem>
                <PropertyName>objKey</PropertyName>
              </TableColumnItem>
              <TableColumnItem>
                <PropertyName>name</PropertyName>
              </TableColumnItem>
              <TableColumnItem>
                <ScriptBlock>
                  $t = ([string]$_.description) -replace "(`r`n)|`r|`n", " "
                  if ($t.Length -gt 20) {
                    $t.Substring(0, 20) + '…'
                  }
                  else {
                    $t
                  }
                </ScriptBlock>
              </TableColumnItem>
              <TableColumnItem>
                <PropertyName>updated</PropertyName>
              </TableColumnItem>
            </TableColumnItems>
          </TableRowEntry>
        </TableRowEntries>
      </TableControl>
    </View>

