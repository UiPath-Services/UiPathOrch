    <View>
      <Name>UserRoles</Name>
      <ViewSelectedBy>
        <TypeName>UiPath.PowerShell.Entities.UserRoles</TypeName>
      </ViewSelectedBy>
      <GroupBy>
        <Label>Directory</Label>
        <PropertyName>Path</PropertyName>
      </GroupBy>
      <TableControl>
        <TableHeaders>
          <TableColumnHeader>
            <Label>Id</Label>
          </TableColumnHeader>
          <TableColumnHeader>
            <Label>UserEntity.Type</Label>
          </TableColumnHeader>
          <TableColumnHeader>
            <Label>UserEntity.UserName</Label>
          </TableColumnHeader>
          <TableColumnHeader>
            <Label>HasAlertsEnabled</Label>
          </TableColumnHeader>
          <TableColumnHeader>
            <Label>RobotType</Label>
          </TableColumnHeader>
          <TableColumnHeader>
            <Label>Roles</Label>
          </TableColumnHeader>
        </TableHeaders>
        <TableRowEntries>
          <TableRowEntry>
            <TableColumnItems>
              <TableColumnItem>
                <PropertyName>Id</PropertyName>
                <Alignment>right</Alignment>
              </TableColumnItem>
              <TableColumnItem>
                <ScriptBlock>$_.UserEntity.Type</ScriptBlock>
              </TableColumnItem>
              <TableColumnItem>
                <ScriptBlock>$_.UserEntity.UserName</ScriptBlock>
              </TableColumnItem>
              <TableColumnItem>
                <PropertyName>HasAlertsEnabled</PropertyName>
              </TableColumnItem>
              <TableColumnItem>
                <ScriptBlock>
                  $robottype = @()
                  $attended = if ($_.UserEntity.MayHaveAttended) { $robottype += "Attended" }
                  $unattended = if ($_.UserEntity.MayHaveUnattended) { $robottype += "Unattended" }
                  $robottype -join ', '
                </ScriptBlock>
              </TableColumnItem>
              <TableColumnItem>
                <ScriptBlock>
                  $concatenatedRoles = [string]::Join(", ", $_.Roles.Name)
                  $concatenatedRoles
                </ScriptBlock>
              </TableColumnItem>
            </TableColumnItems>
          </TableRowEntry>
        </TableRowEntries>
      </TableControl>
    </View>

