    <View>
      <Name>LicenseRuntime</Name>
      <ViewSelectedBy>
        <TypeName>UiPath.PowerShell.Entities.LicenseRuntime</TypeName>
      </ViewSelectedBy>
      <GroupBy>
        <Label>RobotType</Label>
        <PropertyName>Path</PropertyName>
      </GroupBy>
      <TableControl>
        <TableHeaders>
          <TableColumnHeader>
            <Label>HostMachineName</Label>
          </TableColumnHeader>
          <TableColumnHeader>
            <Label>ServiceUserName</Label>
          </TableColumnHeader>
          <TableColumnHeader>
            <Label>Template</Label>
          </TableColumnHeader>
          <TableColumnHeader>
            <Label>Runtimes</Label>
            <Alignment>right</Alignment>
          </TableColumnHeader>
          <TableColumnHeader>
            <Label>Robots</Label>
            <Alignment>right</Alignment>
          </TableColumnHeader>
          <TableColumnHeader>
            <Label>ExecutingCount</Label>
            <Alignment>right</Alignment>
          </TableColumnHeader>
          <TableColumnHeader>
            <Label>IsLicensed</Label>
          </TableColumnHeader>
          <TableColumnHeader>
            <Label>Enabled</Label>
          </TableColumnHeader>
        </TableHeaders>
        <TableRowEntries>
          <TableRowEntry>
            <TableColumnItems>
              <TableColumnItem>
                <PropertyName>HostMachineName</PropertyName>
              </TableColumnItem>
              <TableColumnItem>
                <PropertyName>ServiceUserName</PropertyName>
              </TableColumnItem>
              <TableColumnItem>
                <ScriptBlock>if ($_.MachineType -eq 'Template') { $_.MachineName }</ScriptBlock>
              </TableColumnItem>
              <TableColumnItem>
                <PropertyName>Runtimes</PropertyName>
                <Alignment>right</Alignment>
              </TableColumnItem>
              <TableColumnItem>
                <ScriptBlock>if ($_.MachineType -eq 'Template') { 'N/A' } else { $_.RobotsCount }</ScriptBlock>
                <Alignment>right</Alignment>
              </TableColumnItem>
              <TableColumnItem>
                <PropertyName>ExecutingCount</PropertyName>
                <Alignment>right</Alignment>
              </TableColumnItem>
              <TableColumnItem>
                <ScriptBlock>$esc = [char]27; $d = [char]0x25CF; if ($_.IsLicensed) { "$($esc)[38;5;40m$d$($esc)[0m" } else { "$($esc)[38;5;208m$d$($esc)[0m" }</ScriptBlock>
              </TableColumnItem>
              <TableColumnItem>
                <PropertyName>Enabled</PropertyName>
              </TableColumnItem>
            </TableColumnItems>
          </TableRowEntry>
        </TableRowEntries>
      </TableControl>
    </View>

    <View>
      <Name>LicenseStatsModel</Name>
      <ViewSelectedBy>
        <TypeName>UiPath.PowerShell.Entities.LicenseStatsModel</TypeName>
      </ViewSelectedBy>
      <GroupBy>
        <Label>Directory</Label>
        <PropertyName>Path</PropertyName>
      </GroupBy>
      <TableControl>
        <TableHeaders>
